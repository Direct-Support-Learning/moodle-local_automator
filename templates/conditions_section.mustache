{{!
    Conditions section partial for the rule edit page.

    @package   local_automator
    @copyright 2026 DSL
    @license   http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later
}}
<div class="local-automator-conditions mb-4">
    <h4>{{conditionslabel}}</h4>

    {{#hasconditions}}
    <table class="table table-sm generaltable">
        <thead>
            <tr>
                <th>{{#str}}condition_type, local_automator{{/str}}</th>
                <th>{{#str}}description, local_automator{{/str}}</th>
                <th>{{#str}}actions, local_automator{{/str}}</th>
            </tr>
        </thead>
        <tbody>
            {{#conditions}}
            <tr>
                <td>{{type}}</td>
                <td>{{summary}}</td>
                <td>
                    <a href="{{editurl}}" class="btn btn-sm btn-secondary">{{#str}}condition_edit, local_automator{{/str}}</a>
                    <a href="{{deleteurl}}"
                       class="btn btn-sm btn-danger local-automator-confirm-delete"
                       data-confirm="{{#str}}confirmdelete, local_automator{{/str}}">{{#str}}condition_delete, local_automator{{/str}}</a>
                </td>
            </tr>
            {{/conditions}}
        </tbody>
    </table>
    {{/hasconditions}}

    {{^hasconditions}}
    <p class="text-muted small">{{noconditionsmsg}}</p>
    {{/hasconditions}}

    {{^isnewrule}}
    <div class="local-automator-add-condition mt-2" data-region="add-condition">
        <select class="custom-select" id="local-automator-add-condition-select" data-action="add-condition">
            <option value="">{{selectcondlabel}}</option>
            {{#conditiontypes}}
            <option value="{{url}}">{{name}}</option>
            {{/conditiontypes}}
        </select>
    </div>
    {{/isnewrule}}
    {{#isnewrule}}
    <p class="text-muted small">{{saverulefirstmsg}}</p>
    {{/isnewrule}}
</div>
